# ── NexPanel Configuration ──────────────────────────────────────────────────

# Panel
PORT=3000
HOST=0.0.0.0

# Database (auto-created on first start)
DB_PATH=./data/nexpanel.db

# Admin account (only used on very first start, then ignored)
ADMIN_EMAIL=admin@nexpanel.local
ADMIN_PASS=admin123

# JWT secret (auto-generated if not set)
JWT_SECRET=

# Docker socket
# Linux:
DOCKER_SOCKET=/var/run/docker.sock
# Windows (Docker Desktop):
# DOCKER_SOCKET=//./pipe/docker_engine

# Backups storage path (default: ./backups)
BACKUP_PATH=./backups

# SFTP
SFTP_PORT=2022
SFTP_HOST_KEY_PATH=./data/sftp_host_key

# Mod installer
CURSEFORGE_API_KEY=

# Email (SMTP) for notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NexPanel <nexpanel@example.com>
